# Frenchly — Environment Variables
# Copy this file to .env.local and fill in real values from your Supabase dashboard.
# .env.local is gitignored and must NEVER be committed.

# ── Supabase (Public — safe for client bundles) ──────────────────────────────
# Project Settings -> Data API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Project Settings -> API Keys -> Publishable key (client-safe)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase (Secret — SERVER ONLY, never add NEXT_PUBLIC_ prefix) ───────────
# Project Settings -> API Keys -> Secret key
# WARNING: This key bypasses Row Level Security. Keep it server-side only.
SUPABASE_SECRET_KEY=

# ── Site URL ─────────────────────────────────────────────────────────────────
# Used for password-reset redirect URLs.
# Local dev: http://localhost:3000
# Production: your Vercel deployment URL (e.g. https://frenchly.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
